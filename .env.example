# This is the default configuration File for this project
# For local development, you should avoid changing anything except for App config values
# Use artisan key:generate for APP_KEY to be set

# App Config
APP_ENV=local
APP_DEBUG=true
APP_LOCALE=de
LOG_LEVEL=debug

# Change this in case you want to use something else than localhost with port 80
APP_URL=http://localhost
APP_PORT=80

# Database Config
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

# Email Config
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Redis Config
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# External Services Config
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI="${APP_URL}/auth/twitch/callback"

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# no touchy if unsure
APP_KEY=
QUEUE_CONNECTION=database
CACHE_STORE=database
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_SLOW_QUERIES_CHANNEL=stderr
LOG_STACK=daily,stderr
LOG_DEPRECATIONS_CHANNEL=null

DB_SLOW_QUERY_THRESHOLD=350
DB_SLOW_QUERIES_THRESHOLD=5000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

APP_NAME="VHeart Clips"
VITE_APP_NAME="${APP_NAME}"
